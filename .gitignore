# Sibling service/ui/tf/etc repos are their own git repos.
# Anchor with a leading slash so the pattern only matches at the workspace
# root and doesn't accidentally swallow .kiro/specs/caslearn-olms/.
/caslearn-*/

# But never ignore anything inside .kiro/ — that's the content this repo owns.
!.kiro/
!.kiro/**

# In case this repo itself is ever cloned as a sibling.
!/caslearn-kiro-docs/
